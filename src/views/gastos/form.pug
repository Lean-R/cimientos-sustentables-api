doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Nuevo gasto

  body
    h1#titulo Nuevo gasto
    p#descripcion Completá los datos para registrar un gasto.

    form#formGasto
      input(type="hidden" id="obra_id" name="obra_id" value=obraId)
      input(type="hidden" id="partida_id" name="partida_id" value=partidaId)

      br

      div
        label(for="fecha") Fecha:
        input(type="date" id="fecha" name="fecha" value=(new Date().toISOString().split('T')[0]))

      br

      div
        label(for="concepto") Rubro:
        select(id="concepto" name="concepto")
          option(value="") Seleccionar
          option(value="Trabajos preliminares y gestión verde") Trabajos preliminares y gestión verde
          option(value="Infraestructura y fundaciones") Infraestructura y fundaciones
          option(value="Envolvente sustentable") Envolvente sustentable
          option(value="Aberturas de alta prestación") Aberturas de alta prestación
          option(value="Instalaciones Bio-eficientes") Instalaciones Bio-eficientes
          option(value="Revestimientos y Terminaciones") Revestimientos y Terminaciones 
          option(value="Limpieza y Entrega") Limpieza y Entrega

      br

      div
        label(for="proveedor") Proveedor:
        input(type="text" id="proveedor" name="proveedor")

      br

      div
        label(for="monto") Monto:
        input(type="number" id="monto" name="monto")

      br

      div
        label(for="estado") Estado:
        select(id="estado" name="estado")
          option(value="") Seleccionar
          option(value="Solicitado") Solicitado
          option(value="Autorizado") Autorizado
          option(value="Pagado") Pagado

      br

      button(type="submit" id="guardarGasto") Guardar gasto

      br
      br

      if obraId
        a(href=`/obras/${obraId}`) Volver al detalle de la obra
      else
        a(href="/obras") Volver al listado de obras
  
  script(src="/js/gastos.js")    
doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Detalle de obra

  body
    h1 Detalle de obra

    h2 Datos generales

    p
      strong Nombre:
      |  #{obra.nombre}

    p
      strong Dirección:
      |  #{obra.direccion}

    p
      strong Provincia:
      |  #{obra.provincia}

    p
      strong Director de obra:
      |  #{obra.directorObra}

    p
      strong Teléfono de contacto:
      |  #{obra.telefono}

    p
      strong Tipo de contratación:
      |  #{obra.tipoContratacion}

    p
      strong Estado:
      |  #{obra.estado}

    p
      strong Presupuesto total:
      |  #{obra.presupuesto}

    h2 Partidas Presupuestarias

    div#partidasContainer
      p Cargando partidas...

    p
    a(href=`/partidas/nueva?obraId=${obra.id}`) + Nueva partida

    p
    a(href=`/gastos/nuevo?obraId=${obra.id}`) + Nuevo gasto

    script.
      const obraId = '#{obra.id}';
      
      async function eliminarPartida(partidaId) {
        const confirmar = confirm('¿Estás seguro de que deseás eliminar esta partida presupuestaria?');
        
        if (!confirmar) {
          return;
        }
        
        try {
          const response = await fetch(`/api/partidas/${partidaId}`, {
            method: 'DELETE'
          });
          
          if (!response.ok) {
            throw new Error('Error al eliminar la partida');
          }
          
          alert('¡Partida eliminada correctamente!');
          // Recargar las partidas
          cargarPartidas();
        } catch (error) {
          alert('Error: ' + error.message);
          console.error('Error:', error);
        }
      }
      
      function cargarPartidas() {
        fetch(`/api/partidas?obra_id=${obraId}`)
          .then(response => {
            if (!response.ok) {
              throw new Error('Error en la respuesta del servidor');
            }
            return response.json();
          })
          .then(partidas => {
            const container = document.getElementById('partidasContainer');
            
            if (partidas.length === 0) {
              container.innerHTML = '<p>No hay partidas presupuestarias en esta obra</p>';
              return;
            }
            
            let html = '';
            
            partidas.forEach(partida => {
              html += `
                <div style="margin-bottom: 20px; padding: 10px; border: 1px solid #ddd;">
                  <p>
                    <a href="/partidas/editar?partidaId=${partida.id}&obraId=${obraId}">Editar</a> | 
                    <a href="#" onclick="event.preventDefault(); eliminarPartida('${partida.id}');">Eliminar</a>
                  </p>
                  <p><strong>ID:</strong> ${partida.id}</p>
                  <p><strong>Rubro:</strong> ${partida.rubro}</p>
                  <p><strong>Precio Total:</strong> $${partida.precio_total}</p>
                  
                  <h4>Items:</h4>
                  <table border="1" cellpadding="5" cellspacing="0">
                    <thead>
                      <tr>
                        <th>Detalle</th>
                        <th>Cantidad</th>
                        <th>Unidad de Medida</th>
                        <th>Precio Unitario</th>
                        <th>Precio Parcial</th>
                      </tr>
                    </thead>
                    <tbody>
              `;
              
              partida.items.forEach(item => {
                html += `
                  <tr>
                    <td>${item.detalle}</td>
                    <td>${item.cantidad}</td>
                    <td>${item.unidad_medida}</td>
                    <td>$${item.precio_unitario}</td>
                    <td>$${item.precio_parcial}</td>
                  </tr>
                `;
              });
              
              html += `
                    </tbody>
                  </table>
                </div>
              `;
            });
            
            container.innerHTML = html;
          })
          .catch(error => {
            const container = document.getElementById('partidasContainer');
            container.innerHTML = '<p style="color: red;">No se pudieron cargar las partidas</p>';
            console.error('Error:', error);
          });
      }
      
      // Cargar partidas al iniciar la página
      cargarPartidas();


    hr

    h2 Gastos registrados

    table(border="1")
      thead
        tr
          th Fecha
          th Partida
          th Monto
          th Estado
      tbody
        each gasto in gastos
          tr
            td= gasto.fecha
            td= gasto.partidaRubro
            td= gasto.monto
            td= gasto.estado
        
    p
      strong Total gastos registrados:
      |  $#{totalGastos}

    hr

    p
      a(href="/obras") Volver al listado
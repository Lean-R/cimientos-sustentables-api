doctype html
html
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title= obra ? "Editar obra" : "Nueva obra"

  body
    h1= obra ? "Editar obra" : "Nueva obra"
    p= obra ? "Modificá los datos de la obra seleccionada." : "Completá los datos para registrar una nueva obra."

    form(action="/obras" method="POST")
      div
        label(for="nombre") Nombre:
        input(type="text" id="nombre" name="nombre" value=obra ? obra.nombre : "")

      br

      div
        label(for="direccion") Dirección:
        input(type="text" id="direccion" name="direccion" value=obra ? obra.direccion : "")

      br

      div
        label(for="provincia") Provincia:
        input(type="text" id="provincia" name="provincia" value=obra ? obra.provincia : "")

      br

      div
        label(for="directorObra") Director de obra:
        input(type="text" id="directorObra" name="directorObra" value=obra ? obra.directorObra : "")

      br

      div
        label(for="tipoContratacion") Tipo de contratación:
        select(id="tipoContratacion" name="tipoContratacion")
          option(value="") Seleccionar
          option(value="Licitación" selected=obra && obra.tipoContratacion === "Licitación") Licitación
          option(value="Privada" selected=obra && obra.tipoContratacion === "Privada") Privada
          option(value="Inversión" selected=obra && obra.tipoContratacion === "Inversión") Inversión

      br

      div
        label(for="estado") Estado:
        select(id="estado" name="estado")
          option(value="") Seleccionar
          option(value="Trámites" selected=obra && obra.estado === "Trámites") Trámites
          option(value="Planificación" selected=obra && obra.estado === "Planificación") Planificación
          option(value="Construcción" selected=obra && obra.estado === "Construcción") Construcción
          option(value="Cierre" selected=obra && obra.estado === "Cierre") Cierre

      br

      div
        label(for="presupuesto") Presupuesto total:
        input(type="text" id="presupuesto" name="presupuesto" value=obra ? obra.presupuesto : "")

      br

      button(type="submit")= obra ? "Actualizar obra" : "Guardar obra"

      br
      br
      if obra
        a(href=`/obras/${obra.id}`) Volver al detalle de la obra
      else
        a(href="/obras") Volver al listado de obras